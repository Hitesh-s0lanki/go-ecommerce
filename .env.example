# Copy to .env and adjust. .env is gitignored; this file is committed.
# The Makefile reads .env, so these values also drive `make migrate-*`.

PORT=8080
# debug | release | test
GIN_MODE=debug
# Comma-separated CORS origins. "*" allows any origin and never sends
# credentials; set explicit origins in production.
ALLOWED_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=ecommerce_shop
DB_SSLMODE=disable

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=72h

# AWS / LocalStack
# The gateway serves every service on 4566.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=ecommerce-uploads
AWS_S3_ENDPOINT=http://localhost:4566

# Uploads
UPLOAD_PATH=./uploads
# 10 MiB, in bytes.
MAX_UPLOAD_SIZE=10485760
