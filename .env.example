# Copy to .env and adjust. .env is gitignored; this file is committed.
# The Makefile reads .env, so these values also drive `make migrate-*`.

PORT=8080
# debug | release | test
GIN_MODE=debug
# Comma-separated CORS origins. "*" allows any origin and never sends
# credentials; set explicit origins in production.
ALLOWED_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=ecommerce_shop
DB_SSLMODE=disable

# Auth
# HS256 needs at least 32 bytes. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_do_not_use
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=72h

# AWS / LocalStack
# The gateway serves every service on 4566.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=ecommerce-uploads
AWS_S3_ENDPOINT=http://localhost:4566
# Separate from the S3 endpoint: LocalStack serves both on one port, a real
# deployment does not.
AWS_SQS_ENDPOINT=http://localhost:4566

# Uploads
# Where uploaded files go: "local" writes to UPLOAD_PATH, "s3" writes to
# AWS_S3_BUCKET. Local is for development and single boxes — a second instance
# cannot serve what this one wrote, and a redeploy that replaces the disk
# loses every file.
UPLOAD_PROVIDER=local
# Only used by the local provider.
UPLOAD_PATH=./uploads
# 10 MiB, in bytes. Enforced on the request body, not just the stored file.
MAX_UPLOAD_SIZE=10485760
# Where clients fetch uploaded files from.
#
# Empty means the API serves them itself at /uploads, which only works with the
# local provider. The compose file runs a CDN that serves both providers from
# one URL, so this can stay put while UPLOAD_PROVIDER changes:
#
#   UPLOAD_PUBLIC_BASE_URL=http://localhost:8081/uploads
#
# In production this should be the CDN or bucket domain in front of the files.
UPLOAD_PUBLIC_BASE_URL=

# The CDN container's port on the host.
CDN_PORT=8081

# Events
# Domain events (user.registered, user.logged_in) are published to SQS, where a
# consumer can act on them. False discards them, and the API runs with no queue.
#
# Publishing is best-effort either way: a queue outage is logged, never a failed
# login. The queue must already exist — docker/init/aws/init-localstack.sh
# creates it for LocalStack.
EVENTS_ENABLED=true
AWS_EVENT_QUEUE_NAME=ecommerce-events
